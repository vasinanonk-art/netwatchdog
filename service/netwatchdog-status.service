[Unit]
Description=NetWatchDog Shared Runtime Status Writer
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/netwatchdog
ExecStart=/usr/bin/python3 /opt/netwatchdog/status_writer.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
