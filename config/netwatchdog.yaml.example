primary:
  interface: wlx6c4cbcdb7033
  ip: 192.168.1.61
  metric: 100

backup:
  interface: wlan0
  ip: 192.168.1.60
  metric: 600

gateway:
  host: 192.168.1.1

internet:
  host: 1.1.1.1

status:
  path: /run/netwatchdog/status.json
  interval: 10

history:
  path: /var/lib/netwatchdog/history.json
  interval: 10
  retention_hours: 24

event:
  log: /var/log/netwatchdog/events.jsonl

watchdog:
  wifi_fail_limit: 3
  wifi_recover_limit: 3
  heal_cooldown: 300
  service_fail_limit: 3
  service_heal_cooldown: 300

# Backup Wi-Fi is observed at low frequency while USB primary is healthy.
# These keys are read from the merged network configuration.
network:
  onboard_probe_interval_sec: 60
  onboard_heal_failure_duration_sec: 600
  onboard_heal_max_per_hour: 3

oled:
  enabled: true
  pixel_shift: true
  screen_saver_sec: 300
  day_brightness: 160
  night_brightness: 32
  popup_timeout_sec: 8

web:
  host: 0.0.0.0
  port: 8080
